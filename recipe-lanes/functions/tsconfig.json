{
  "compilerOptions": {
    "rootDir": "..",

    "module": "NodeNext",
    "esModuleInterop": true,
    "moduleResolution": "nodenext",
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "isolatedModules": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "skipLibCheck": true,
    "typeRoots": [
      "./node_modules/@types"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["../*"]
    }
  },
  "compileOnSave": true,
  "include": [
    "src",
    // "../lib" Don't include this, path automatically brings in what's needed.
  ]
}
