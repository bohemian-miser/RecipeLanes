{
  "name": "recipe-rpg-simple",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 8001",
    "build": "next build",
    "start": "next start -p 8001",
    "lint": "eslint",
    "pretest": "fuser -k 8001/tcp; fuser -k 3000/tcp || true",
    "test": "npx tsx tests/lifecycle.test.ts && npx tsx tests/graph-utils.test.ts && npx tsx tests/undo.test.ts && npx tsx tests/undo-complex.test.ts && npx tsx tests/undo-scrambled-logic.test.ts && npx tsx tests/social-features.test.ts && npx playwright test",
    "mcp": "npx tsx scripts/mcp-server.ts",
    "emulators": "./scripts/start-emulators.sh",
    "dev:emulators": "NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 STORAGE_EMULATOR_HOST=127.0.0.1:9199 next dev -p 8001",
    "verify": "npm run build && npm test",
    "prepare": "cd .. && git config core.hooksPath recipe-rpg-simple/.husky"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "@genkit-ai/firebase": "^1.26.0",
    "@genkit-ai/google-genai": "^1.25.0",
    "@types/dagre": "^0.7.53",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "d3-hierarchy": "^3.1.2",
    "d3-shape": "^3.2.0",
    "dagre": "^0.8.5",
    "dotenv": "^17.2.3",
    "elkjs": "^0.11.0",
    "firebase": "^12.6.0",
    "firebase-admin": "^13.6.0",
    "genkit": "^1.26.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.559.0",
    "next": "^16.1.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "reactflow": "^11.11.4",
    "tailwind-merge": "^3.4.0",
    "web-worker": "^1.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.0.8",
    "firebase-tools": "^15.1.0",
    "husky": "^9.1.7",
    "jsdom": "^27.3.0",
    "node-fetch": "^3.3.2",
    "playwright": "^1.57.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
