{
  "name": "recipe-lanes",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 8001",
    "dev:staging": "npx env-cmd -f .env.staging next dev -p 8001",
    "build": "next build",
    "start": "next start -p 8001",
    "lint": "eslint",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "./scripts/test-unit.sh",
    "test:watch": "node --import tsx --test --watch tests/*.test.ts",
    "test:integration": "export JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64 && export PATH=$JAVA_HOME/bin:$PATH && export GOOGLE_APPLICATION_CREDENTIALS=$(pwd)/service-account.json && env-cmd -f .env.test npm install --prefix functions && env-cmd -f .env.test npm run build --prefix functions && env-cmd -f .env.test npx firebase emulators:exec --only auth,firestore,storage,functions --project local-project-id 'npx tsx tests/functions-metadata.test.ts'",
    "test:e2e": "./scripts/test-e2e.sh",
    "mcp": "npx tsx scripts/mcp-server.ts",
    "emulators": "./scripts/start-emulators.sh",
    "dev:old_emulators": "MOCK_AI=true NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 STORAGE_EMULATOR_HOST=127.0.0.1:9199 next dev -p 8001",
    "dev:emulators": "env-cmd -f .env.test next dev -p 8001",
    "verify": "npm run build && npm test",
    "prepare": "if [ -d ../.git ]; then cd .. && git config core.hooksPath recipe-lanes/.husky; fi"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "@genkit-ai/firebase": "^1.26.0",
    "@genkit-ai/google-genai": "^1.27.0",
    "@types/dagre": "^0.7.53",
    "@types/uuid": "^11.0.0",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "d3-hierarchy": "^3.1.2",
    "d3-shape": "^3.2.0",
    "dagre": "^0.8.5",
    "dotenv": "^17.2.3",
    "elkjs": "^0.11.0",
    "firebase": "^12.11.0",
    "genkit": "^1.26.0",
    "html-to-image": "^1.11.13",
    "jpeg-js": "^0.4.4",
    "lucide-react": "^0.559.0",
    "next": "^16.1.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "reactflow": "^11.11.4",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "web-worker": "^1.5.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@types/jpeg-js": "^0.3.7",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20",
    "@types/node-fetch": "^2.6.13",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sharp": "^0.31.1",
    "dotenv-cli": "^11.0.0",
    "env-cmd": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.8",
    "firebase-admin": "^13.6.0",
    "firebase-tools": "^15.1.0",
    "husky": "^9.1.7",
    "jsdom": "^27.3.0",
    "node-fetch": "^3.3.2",
    "playwright": "^1.57.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
