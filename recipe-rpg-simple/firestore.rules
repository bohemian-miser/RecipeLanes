rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Ingredients & Icons: Public Read (needed for cache display)
    match /ingredients/{ingredientId} {
      allow read: if true;
      match /icons/{iconId} {
        allow read: if true;
      }
    }

    // Recipes
    match /recipes/{recipeId} {
      // Allow read if public, unlisted (link sharing), or owned by user
      allow read: if resource.data.visibility == 'public' 
                  || resource.data.visibility == 'unlisted'
                  || (request.auth != null && request.auth.uid == resource.data.ownerId);
    }
    
    // User Profiles & Stars
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /stars/{starId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Icon Generation Queue: Public Read (for monitor)
    match /icon_queue/{ingredient} {
      allow read, write: if true;
    }
  }
}