{
  "name": "functions",
  "scripts": {
    "lint": "eslint .",
    "download-model": "node scripts/download-model.js",
    "build": "tsc && ([ -d src/vector-search/data ] && cp -r src/vector-search/data lib/functions/src/vector-search/ || true) && ([ -d src/vector-search/model-cache ] && cp -rL src/vector-search/model-cache lib/functions/src/vector-search/ || true)",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "jest"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/functions/src/index.js",
  "dependencies": {
    "@genkit-ai/firebase": "^1.26.0",
    "@genkit-ai/google-genai": "^1.25.0",
    "@huggingface/transformers": "^4.0.1",
    "clsx": "^2.1.1",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.3",
    "genkit": "^1.26.0",
    "jpeg-js": "^0.4.4",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/jpeg-js": "^0.3.7",
    "@types/pngjs": "^6.0.5",
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase-functions-test": "^3.1.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5"
  },
  "private": true
}
